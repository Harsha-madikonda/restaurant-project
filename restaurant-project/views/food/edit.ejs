<%- include('../partials/header') %>

<div class="form-page">
  <div class="form-card">
    <div class="form-card-header">
      <h2><i class="fas fa-edit"></i> Edit Food Item</h2>
      <a href="/food" class="btn btn-outline btn-sm"><i class="fas fa-arrow-left"></i> Back</a>
    </div>

    <form action="/food/edit/<%= food._id %>?_method=PUT" method="POST" enctype="multipart/form-data" class="main-form">
      <div class="form-row">
        <div class="form-group">
          <label for="name">Item Name *</label>
          <input type="text" id="name" name="name" value="<%= food.name %>" required />
        </div>
        <div class="form-group">
          <label for="price">Price (₹) *</label>
          <input type="number" id="price" name="price" value="<%= food.price %>" min="0" step="0.01" required />
        </div>
      </div>

      <div class="form-group">
        <label for="description">Description *</label>
        <textarea id="description" name="description" rows="3" required><%= food.description %></textarea>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>Category *</label>
          <div class="radio-group">
            <label class="radio-option">
              <input type="radio" name="category" value="Veg" <%= food.category === 'Veg' ? 'checked' : '' %> />
              <span class="radio-card"><span class="dot dot-green"></span> Vegetarian</span>
            </label>
            <label class="radio-option">
              <input type="radio" name="category" value="Non-Veg" <%= food.category === 'Non-Veg' ? 'checked' : '' %> />
              <span class="radio-card"><span class="dot dot-red"></span> Non-Vegetarian</span>
            </label>
          </div>
        </div>
        <div class="form-group">
          <label>Availability</label>
          <label class="toggle-switch">
            <input type="checkbox" name="available" <%= food.available ? 'checked' : '' %> />
            <span class="toggle-slider"></span>
            <span class="toggle-label">Available</span>
          </label>
        </div>
      </div>

      <div class="form-group">
        <label>Current Image</label>
        <% if (food.image) { %>
          <div style="margin-bottom:0.75rem">
            <img src="<%= food.image %>" alt="<%= food.name %>" style="max-height:160px; border-radius:8px; border:1px solid var(--border);" />
          </div>
        <% } %>
        <label for="image">Replace Image</label>
        <div class="file-upload">
          <input type="file" id="image" name="image" accept="image/*" onchange="previewImage(this)" />
          <div class="file-upload-ui" id="fileUploadUI">
            <i class="fas fa-cloud-upload-alt"></i>
            <p>Click to upload a new image</p>
            <small>JPG, PNG, GIF up to 5MB</small>
          </div>
          <img id="imagePreview" src="" alt="Preview" style="display:none; max-height:160px; border-radius:8px; margin-top:1rem;" />
        </div>
      </div>

      <div class="form-actions">
        <a href="/food" class="btn btn-outline">Cancel</a>
        <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save Changes</button>
      </div>
    </form>
  </div>
</div>

<script>
  function previewImage(input) {
    if (input.files && input.files[0]) {
      const reader = new FileReader();
      reader.onload = e => {
        const preview = document.getElementById('imagePreview');
        preview.src = e.target.result;
        preview.style.display = 'block';
        document.getElementById('fileUploadUI').style.display = 'none';
      };
      reader.readAsDataURL(input.files[0]);
    }
  }
</script>

<%- include('../partials/footer') %>

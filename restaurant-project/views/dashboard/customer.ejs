<%- include('../partials/header') %>

<div class="dashboard-stats">
  <div class="stat-card stat-orange">
    <div class="stat-icon"><i class="fas fa-burger"></i></div>
    <div class="stat-info">
      <span class="stat-value"><%= foods.length %></span>
      <span class="stat-label">Menu Items</span>
    </div>
  </div>
  <div class="stat-card stat-green">
    <div class="stat-icon"><i class="fas fa-receipt"></i></div>
    <div class="stat-info">
      <span class="stat-value"><%= orders.length %></span>
      <span class="stat-label">My Orders</span>
    </div>
  </div>
  <div class="stat-card stat-blue">
    <div class="stat-icon"><i class="fas fa-indian-rupee-sign"></i></div>
    <div class="stat-info">
      <span class="stat-value">₹<%= orders.reduce((s,o)=>s+o.totalPrice,0).toFixed(0) %></span>
      <span class="stat-label">Total Spent</span>
    </div>
  </div>
  <div class="stat-card stat-purple">
    <div class="stat-icon"><i class="fas fa-clock"></i></div>
    <div class="stat-info">
      <span class="stat-value"><%= orders.filter(o=>o.status==='Pending').length %></span>
      <span class="stat-label">Pending Orders</span>
    </div>
  </div>
</div>

<div class="charts-grid">
  <div class="chart-card chart-large">
    <div class="chart-header">
      <h3><i class="fas fa-chart-bar"></i> My Order History</h3>
    </div>
    <canvas id="orderHistoryChart" height="130"></canvas>
  </div>
  <div class="chart-card">
    <div class="chart-header">
      <h3><i class="fas fa-utensils"></i> Quick Order</h3>
    </div>
    <div class="quick-order">
      <p>Ready to eat? Browse the menu and place an order.</p>
      <a href="/orders/cart" class="btn btn-primary btn-full" style="margin-top:1rem">
        <i class="fas fa-cart-shopping"></i> Place Order Now
      </a>
      <a href="/food" class="btn btn-outline btn-full" style="margin-top:0.75rem">
        <i class="fas fa-burger"></i> Browse Menu
      </a>
    </div>
  </div>
</div>

<div class="section-card">
  <div class="section-header">
    <h3><i class="fas fa-clock-rotate-left"></i> Recent Orders</h3>
    <a href="/orders" class="btn btn-outline btn-sm">View All</a>
  </div>
  <% if (orders.length === 0) { %>
    <div class="empty-state">
      <i class="fas fa-receipt"></i>
      <p>You haven't placed any orders yet.</p>
      <a href="/orders/cart" class="btn btn-primary" style="margin-top:1rem">Place Your First Order</a>
    </div>
  <% } else { %>
    <div class="table-wrapper">
      <table class="data-table">
        <thead>
          <tr>
            <th>Order ID</th>
            <th>Items</th>
            <th>Total</th>
            <th>Status</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          <% orders.forEach(order => { %>
            <tr>
              <td class="td-mono">#<%= order._id.toString().slice(-6).toUpperCase() %></td>
              <td><%= order.items.map(i => i.name).join(', ') %></td>
              <td class="td-price">₹<%= order.totalPrice.toFixed(2) %></td>
              <td><span class="badge badge-<%= order.status.toLowerCase() %>"><%= order.status %></span></td>
              <td><%= new Date(order.createdAt).toLocaleDateString('en-IN') %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<div class="section-card">
  <div class="section-header">
    <h3><i class="fas fa-star"></i> Available Menu Items</h3>
    <a href="/food" class="btn btn-outline btn-sm">View All</a>
  </div>
  <div class="food-grid">
    <% foods.slice(0, 6).forEach(food => { %>
      <div class="food-card">
        <div class="food-card-img">
          <% if (food.image) { %>
            <img src="<%= food.image %>" alt="<%= food.name %>" />
          <% } else { %>
            <div class="food-card-placeholder"><i class="fas fa-burger"></i></div>
          <% } %>
          <span class="food-badge food-badge-<%= food.category === 'Veg' ? 'veg' : 'nonveg' %>">
            <%= food.category %>
          </span>
        </div>
        <div class="food-card-body">
          <h4><%= food.name %></h4>
          <p><%= food.description.substring(0, 60) %>...</p>
          <div class="food-card-footer">
            <span class="food-price">₹<%= food.price.toFixed(2) %></span>
            <a href="/orders/cart" class="btn btn-primary btn-sm">Order</a>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
</div>

<script>
  const orderHistory = <%- orderHistory %>;
  new Chart(document.getElementById('orderHistoryChart'), {
    type: 'bar',
    data: {
      labels: orderHistory.length ? orderHistory.map(d => d._id) : ['No orders yet'],
      datasets: [{
        label: 'Orders',
        data: orderHistory.map(d => d.count),
        backgroundColor: 'rgba(231,111,55,0.8)',
        borderRadius: 6,
      }, {
        label: 'Spent (₹)',
        data: orderHistory.map(d => d.spent),
        type: 'line',
        borderColor: '#3498db',
        backgroundColor: 'rgba(52,152,219,0.1)',
        tension: 0.4,
        yAxisID: 'y1',
      }]
    },
    options: {
      responsive: true,
      interaction: { mode: 'index', intersect: false },
      scales: {
        y: { beginAtZero: true, ticks: { stepSize: 1 } },
        y1: { type: 'linear', position: 'right', beginAtZero: true, grid: { drawOnChartArea: false } }
      }
    }
  });
</script>

<%- include('../partials/footer') %>

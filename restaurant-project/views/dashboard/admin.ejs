<%- include('../partials/header') %>

<div class="dashboard-stats">
  <div class="stat-card stat-orange">
    <div class="stat-icon"><i class="fas fa-burger"></i></div>
    <div class="stat-info">
      <span class="stat-value"><%= totalFoods %></span>
      <span class="stat-label">Food Items</span>
    </div>
  </div>
  <div class="stat-card stat-green">
    <div class="stat-icon"><i class="fas fa-receipt"></i></div>
    <div class="stat-info">
      <span class="stat-value"><%= totalOrders %></span>
      <span class="stat-label">Total Orders</span>
    </div>
  </div>
  <div class="stat-card stat-blue">
    <div class="stat-icon"><i class="fas fa-users"></i></div>
    <div class="stat-info">
      <span class="stat-value"><%= totalUsers %></span>
      <span class="stat-label">Registered Users</span>
    </div>
  </div>
  <div class="stat-card stat-purple">
    <div class="stat-icon"><i class="fas fa-indian-rupee-sign"></i></div>
    <div class="stat-info">
      <span class="stat-value" id="totalRevenue">—</span>
      <span class="stat-label">Total Revenue</span>
    </div>
  </div>
</div>

<div class="charts-grid">
  <div class="chart-card chart-large">
    <div class="chart-header">
      <h3><i class="fas fa-chart-bar"></i> Orders & Revenue (Last 7 Days)</h3>
    </div>
    <canvas id="ordersChart" height="120"></canvas>
  </div>
  <div class="chart-card">
    <div class="chart-header">
      <h3><i class="fas fa-chart-pie"></i> Menu Categories</h3>
    </div>
    <canvas id="categoryChart" height="200"></canvas>
  </div>
</div>

<div class="chart-card" style="margin-bottom:2rem">
  <div class="chart-header">
    <h3><i class="fas fa-chart-line"></i> Monthly Revenue</h3>
  </div>
  <canvas id="revenueChart" height="100"></canvas>
</div>

<div class="section-card">
  <div class="section-header">
    <h3><i class="fas fa-clock-rotate-left"></i> Recent Orders</h3>
    <a href="/orders" class="btn btn-outline btn-sm">View All</a>
  </div>
  <% if (recentOrders.length === 0) { %>
    <div class="empty-state">
      <i class="fas fa-receipt"></i>
      <p>No orders yet.</p>
    </div>
  <% } else { %>
    <div class="table-wrapper">
      <table class="data-table">
        <thead>
          <tr>
            <th>Customer</th>
            <th>Items</th>
            <th>Total</th>
            <th>Status</th>
            <th>Date</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% recentOrders.forEach(order => { %>
            <tr>
              <td>
                <div class="td-user">
                  <div class="td-avatar"><%= order.customer ? order.customer.name.charAt(0).toUpperCase() : '?' %></div>
                  <div>
                    <div class="td-name"><%= order.customer ? order.customer.name : 'Deleted User' %></div>
                    <div class="td-email"><%= order.customer ? order.customer.email : '' %></div>
                  </div>
                </div>
              </td>
              <td><%= order.items.length %> item(s)</td>
              <td class="td-price">₹<%= order.totalPrice.toFixed(2) %></td>
              <td><span class="badge badge-<%= order.status.toLowerCase() %>"><%= order.status %></span></td>
              <td><%= new Date(order.createdAt).toLocaleDateString('en-IN') %></td>
              <td>
                <a href="/orders/<%= order._id %>" class="btn btn-ghost btn-sm"><i class="fas fa-eye"></i></a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<script>
  const ordersPerDay = <%- ordersPerDay %>;
  const categoryDist = <%- categoryDist %>;
  const monthlyRevenue = <%- monthlyRevenue %>;

  // Calculate total revenue
  const totalRev = monthlyRevenue.reduce((sum, m) => sum + m.total, 0);
  document.getElementById('totalRevenue').textContent = '₹' + totalRev.toFixed(0);

  // Orders per day chart
  const orderLabels = ordersPerDay.map(d => d._id);
  const orderCounts = ordersPerDay.map(d => d.count);
  const orderRevenue = ordersPerDay.map(d => d.revenue);

  new Chart(document.getElementById('ordersChart'), {
    type: 'bar',
    data: {
      labels: orderLabels.length ? orderLabels : ['No data'],
      datasets: [
        {
          label: 'Orders',
          data: orderCounts,
          backgroundColor: 'rgba(231, 111, 55, 0.8)',
          borderRadius: 6,
          yAxisID: 'y',
        },
        {
          label: 'Revenue (₹)',
          data: orderRevenue,
          type: 'line',
          borderColor: '#2ecc71',
          backgroundColor: 'rgba(46,204,113,0.1)',
          tension: 0.4,
          fill: true,
          yAxisID: 'y1',
        }
      ]
    },
    options: {
      responsive: true,
      interaction: { mode: 'index', intersect: false },
      plugins: { legend: { position: 'top' } },
      scales: {
        y: { type: 'linear', position: 'left', beginAtZero: true, ticks: { stepSize: 1 } },
        y1: { type: 'linear', position: 'right', beginAtZero: true, grid: { drawOnChartArea: false } }
      }
    }
  });

  // Category pie chart
  new Chart(document.getElementById('categoryChart'), {
    type: 'doughnut',
    data: {
      labels: categoryDist.map(c => c._id),
      datasets: [{
        data: categoryDist.map(c => c.count),
        backgroundColor: ['#27ae60', '#e74c3c'],
        borderWidth: 0,
      }]
    },
    options: {
      responsive: true,
      plugins: {
        legend: { position: 'bottom' },
      }
    }
  });

  // Monthly revenue line chart
  new Chart(document.getElementById('revenueChart'), {
    type: 'line',
    data: {
      labels: monthlyRevenue.map(m => m._id),
      datasets: [{
        label: 'Revenue (₹)',
        data: monthlyRevenue.map(m => m.total),
        borderColor: '#e76f37',
        backgroundColor: 'rgba(231,111,55,0.12)',
        tension: 0.4,
        fill: true,
        pointRadius: 5,
        pointBackgroundColor: '#e76f37',
      }]
    },
    options: {
      responsive: true,
      plugins: { legend: { display: false } },
      scales: { y: { beginAtZero: true } }
    }
  });
</script>

<%- include('../partials/footer') %>
